# ─── Required ───────────────────────────────────────────────────────────────
# YOU choose this secret before first `docker compose up` — there is no admin UI.
# Share the same value with every Windows client (Token API field).
# Generate:  openssl rand -hex 32
LOL_DIRECTOR_API_TOKEN=change-me-to-a-long-random-secret

# ─── Director / OBS ─────────────────────────────────────────────────────────
REQUIRE_API_TOKEN=true
# Set OBS_ENABLED=true only when OBS régie is reachable (profile full or host OBS)
OBS_ENABLED=false
OBS_HOST=obs
OBS_PORT=4455
OBS_PASSWORD=

# Auto-switch OBS scenes when events arrive
AUTO_MODE=true

# ─── Public domain (Caddy HTTPS) ───────────────────────────────────────────
# Leave empty for HTTP-only on port 80 (dev / IP access)
# Clients use: http://VPS_IP  or  https://DOMAIN  (no :8750 — that's internal)
DOMAIN=
# Example: DOMAIN=regie.example.com

# ─── Ports exposed on VPS ───────────────────────────────────────────────────
RTMP_PORT=1935
HLS_PORT=8080
HTTP_PORT=80
HTTPS_PORT=443

# ─── Player OBS stream settings (copy to each player) ────────────────────────
# Player A OBS:
#   Server:     rtmp://YOUR_VPS_IP:1935/live
#   Stream key: playerA
# Player B OBS:
#   Server:     rtmp://YOUR_VPS_IP:1935/live
#   Stream key: playerB
#
# Preview (optional): http://YOUR_VPS_IP:8080/hls/playerA.m3u8
#
# OBS régie sources (inside docker network):
#   rtmp://rtmp:1935/live/playerA
#   rtmp://rtmp:1935/live/playerB
#
# Full setup guide: SETUP.md

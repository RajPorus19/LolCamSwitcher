# ─── Required ───────────────────────────────────────────────────────────────
# Fixed token shared with Windows client agents (do NOT leave empty in prod)
LOL_DIRECTOR_API_TOKEN=change-me-to-a-long-random-secret

# ─── Director / OBS ─────────────────────────────────────────────────────────
# Set OBS_ENABLED=true only when OBS is reachable (profile full or host OBS)
REQUIRE_API_TOKEN=true
OBS_ENABLED=false
OBS_HOST=obs
OBS_PORT=4455
OBS_PASSWORD=

# Auto-switch OBS scenes when events arrive
AUTO_MODE=true

# ─── Public domain (Caddy HTTPS) ───────────────────────────────────────────
# Leave empty for HTTP-only on port 80 (dev / IP access)
DOMAIN=
# Example: DOMAIN=regie.example.com

# ─── Ports exposed on VPS ───────────────────────────────────────────────────
RTMP_PORT=1935
HLS_PORT=8080
HTTP_PORT=80
HTTPS_PORT=443

# ─── RTMP stream keys (informational — configure in player OBS) ─────────────
# Player A: rtmp://YOUR_VPS_IP:1935/live/playerA
# Player B: rtmp://YOUR_VPS_IP:1935/live/playerB
# OBS regie sources (inside docker network): rtmp://rtmp:1935/live/playerA
